prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/@LIBXSMM_INSTALL_INCLUDEDIR@
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@

Name: libxsmm/f
Description: LIBXSMM for Fortran
URL: https://github.com/libxsmm/libxsmm/
Version: @PROJECT_VERSION@

Requires: libxsmm
Cflags: -I${includedir}
Libs: -L${libdir} -lxsmmf
